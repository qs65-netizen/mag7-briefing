# Email Configuration
# For Outlook, you need to use an App Password
# Learn how to generate an App Password: https://support.microsoft.com/en-us/account-billing/using-app-passwords-with-apps-that-don-t-support-two-step-verification-98937610-431c-4d9a-8d7d-9a6c5a7f5f9c

EMAIL_USER=your.email@outlook.com
EMAIL_PASS=your_app_password_here

# Optional: News API Key (if using NewsAPI.org)
# Get your free API key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here
